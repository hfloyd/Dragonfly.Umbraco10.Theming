@inherits UmbracoViewPage<IPublishedContent>
@{
	Layout = null;
	var currentPage = Model;
	// var thisTheme = currentPage.Value<string>("siteTheme", fallback: Fallback.ToAncestors);
	var thisTheme = ThemeHelper.GetSiteThemeName(Model);
	var templateFilePath = ThemeHelper.GetThemeViewPath(thisTheme, currentPage.GetTemplateAlias());

	var siteCssOverrideFilename = currentPage.Value<string>("siteCssFile", fallback: Fallback.ToAncestors);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0, user-scalable=no" />
    <title>@currentPage.Name</title>
    <meta name="description" content="">

    @* StarterKit base CSS — keeps the shared nav partial working *@
    <link rel="stylesheet" href="@Url.Content("~/css/umbraco-starterkit-style.css")" />

    @* BlueBubbles theme CSS *@
    <link rel="stylesheet" href="@Url.ThemedAsset(ThemeHelper, thisTheme, "css/blue-bubbles.css")" />
	
    @*Testing CSS Override*@
    @if(!string.IsNullOrEmpty(siteCssOverrideFilename))
    {
        <link rel="stylesheet" href="@Url.GetCssOverridePath(ThemeHelper, siteCssOverrideFilename)" />
    }

    @await RenderSectionAsync("HeadScripts", required: false)
</head>
<body class="bb-theme">

    @* Ambient floating bubble shapes *@
    <div class="bb-ambient" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
    </div>

    @* Mobile nav overlay (used by starterkit-app.js) *@
    <div class="mobile-nav">
        <nav class="nav-bar">
            <partial name="Partials/Navigation/TopNavigation" />
        </nav>
    </div>

    @Html.ThemedPartial(ThemeHelper, thisTheme, "_Header", Model)

    <main>
        @RenderBody()
    </main>

    @Html.ThemedPartial(ThemeHelper, thisTheme, "_Footer", Model)

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"
            integrity="sha256-/xUj+3OJU5yExlq6GSYGSHk7tPXikynS7ogEvDej/m4="
            crossorigin="anonymous"></script>
    <script src="@Url.Content("~/scripts/umbraco-starterkit-app.js")"></script>

    @await RenderSectionAsync("FooterScripts", required: false)
</body>
</html>
